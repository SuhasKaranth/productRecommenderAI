# ============================================================================
# Docker Environment Configuration Template
# ============================================================================
# This file contains environment variables for running the application in Docker
#
# USAGE:
#   1. Copy this file: cp .env.docker.example .env.docker
#   2. Update values for your environment
#   3. Run: docker-compose up
#
# IMPORTANT:
#   - .env.docker is in .gitignore - never commit it!
#   - Use different values for dev/staging/prod
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# For Docker Compose: Use service name 'postgres' as hostname
# For production: Use actual database hostname/IP
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/smart_guide_poc
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres_docker_secure_password_CHANGE_ME

# Database Pool Settings (optional - uncomment to customize)
# DB_POOL_MAX_SIZE=20
# DB_POOL_MIN_IDLE=5

# ============================================================================
# LLM PROVIDER CONFIGURATION
# ============================================================================
# Options: 'ollama' or 'azure'
LLM_PROVIDER=ollama

# LLM Ranking Configuration
LLM_RANKING_ENABLED=false
LLM_RANKING_TIMEOUT=30000

# ============================================================================
# AZURE OPENAI CONFIGURATION (Only if LLM_PROVIDER=azure)
# ============================================================================
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your-api-key-here-CHANGE_ME
# AZURE_OPENAI_DEPLOYMENT=gpt-4
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ============================================================================
# OLLAMA CONFIGURATION (Only if LLM_PROVIDER=ollama)
# ============================================================================
# For Docker on Mac/Windows: use host.docker.internal
# For Docker on Linux: use 172.17.0.1 (or your docker0 interface IP)
# For Docker Compose with Ollama service: use service name
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
SERVER_PORT=8080

# ============================================================================
# API KEY AUTHENTICATION
# ============================================================================
# Set to 'false' to disable authentication (NOT recommended for production)
API_KEY_AUTH_ENABLED=true

# ============================================================================
# ADMIN API KEYS (Full Access)
# ============================================================================
# SECURITY: Generate secure keys using:
#   openssl rand -base64 32 | tr -d "=+/" | cut -c1-40
#
# Format: sk_admin_<random_string>
# Minimum 20 characters, must contain at least 2 underscores
#
# IMPORTANT: Use different keys for dev/staging/production!
API_KEY_ADMIN_1=sk_admin_REPLACE_WITH_SECURE_RANDOM_KEY_40_CHARS_MIN
API_KEY_ADMIN_2=sk_admin_REPLACE_WITH_ANOTHER_SECURE_KEY_40_CHARS

# ============================================================================
# USER API KEYS (Limited Access - Read & Recommend Only)
# ============================================================================
# Format: sk_user_<random_string>
API_KEY_USER_1=sk_user_REPLACE_WITH_SECURE_RANDOM_KEY_40_CHARS_MIN
API_KEY_USER_2=sk_user_REPLACE_WITH_ANOTHER_SECURE_KEY_40_CHARS

# ============================================================================
# SCOPED API KEYS (Future Enhancement - Custom Permissions)
# ============================================================================
# Format: sk_scoped_<random_string>
# API_KEY_SCOPED=sk_scoped_CUSTOM_SCOPE_KEY_HERE

# ============================================================================
# LOGGING CONFIGURATION (Optional)
# ============================================================================
# Set to INFO for production, DEBUG for development
# LOG_LEVEL=INFO
# LOG_PATTERN=%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n

# ============================================================================
# JAVA OPTIONS (Optional - JVM Tuning)
# ============================================================================
# For production, tune based on container resources
# JAVA_OPTS=-Xmx1536m -Xms512m -XX:+UseG1GC

# ============================================================================
# SPRING PROFILES (Optional)
# ============================================================================
# Options: dev, staging, prod
# SPRING_PROFILES_ACTIVE=prod

# ============================================================================
# ADDITIONAL CONFIGURATION (Optional)
# ============================================================================
# Recommendation Settings
# RECOMMENDATION_MAX_RESULTS=5
# RECOMMENDATION_CONFIDENCE_THRESHOLD=0.5

# Keywords Generation
# KEYWORDS_MAX=10
# KEYWORDS_TIMEOUT_SECONDS=30

# ============================================================================
# NOTES FOR PRODUCTION DEPLOYMENT
# ============================================================================
# 1. Change all CHANGE_ME values
# 2. Generate new API keys (don't reuse development keys)
# 3. Use strong database password (20+ characters, mixed case, numbers, symbols)
# 4. Set LLM_RANKING_ENABLED=false if Ollama/Azure not available
# 5. Consider using Docker secrets or cloud secret managers for sensitive values
# 6. Enable HTTPS/TLS for production (configure reverse proxy)
# 7. Set up database backups
# 8. Configure monitoring and alerts
#
# SECURITY CHECKLIST:
# [ ] Changed default database password
# [ ] Generated new API keys
# [ ] Set API_KEY_AUTH_ENABLED=true
# [ ] Different keys for each environment
# [ ] .env.docker is in .gitignore
# [ ] Secrets not committed to git
# [ ] File permissions restricted (chmod 600 .env.docker)
# ============================================================================
