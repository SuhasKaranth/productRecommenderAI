# =============================================================================
# REQUIRED — application will fail to start if these are not set
# (unless running with SPRING_PROFILES_ACTIVE=dev, which provides safe defaults)
# =============================================================================

# Database Configuration — REQUIRED in production
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/smart_guide_poc
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# =============================================================================
# OPTIONAL — have built-in defaults; override as needed
# =============================================================================

# LLM Provider (ollama or azure)
LLM_PROVIDER=ollama

# Azure OpenAI Configuration (if using Azure)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Ollama Configuration (if using Ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Server Configuration
SERVER_PORT=8080

# API Key Authentication
# Enable/disable API key authentication (true for production, false for local dev)
API_KEY_AUTH_ENABLED=true

# ADMIN-level API Keys (full access to all endpoints)
# Format: sk_admin_<random_string> (minimum 20 characters)
# Generate secure random keys using: openssl rand -hex 16
# Or use: https://www.uuidgenerator.net/
API_KEY_ADMIN_1=sk_admin_REPLACE_WITH_SECURE_RANDOM_KEY_32_CHARS_MIN
API_KEY_ADMIN_2=sk_admin_REPLACE_WITH_ANOTHER_SECURE_KEY_32_CHARS

# USER-level API Keys (limited to read and recommend endpoints)
# Format: sk_user_<random_string> (minimum 20 characters)
API_KEY_USER_1=sk_user_REPLACE_WITH_SECURE_RANDOM_KEY_32_CHARS_MIN
API_KEY_USER_2=sk_user_REPLACE_WITH_ANOTHER_SECURE_KEY_32_CHARS

# SCOPED API Keys (future enhancement - custom scopes)
# Format: sk_scoped_<random_string>
# API_KEY_SCOPED=sk_scoped_CUSTOM_SCOPE_KEY_HERE

# Scraper Service — API key used by the scraper to call the main app
# Must match one of the ADMIN keys above so it can POST to /api/admin/staging
MAIN_SERVICE_API_KEY=sk_admin_REPLACE_WITH_SECURE_RANDOM_KEY_32_CHARS_MIN

# =============================================================================
# Development Services Auto-Start
# =============================================================================
# Enable to automatically start Frontend and Scraper when backend starts
DEV_SERVICES_ENABLED=false

# Frontend (React) Development Server
DEV_SERVICES_FRONTEND_ENABLED=true
DEV_SERVICES_FRONTEND_PORT=3000

# Scraper Service
DEV_SERVICES_SCRAPER_ENABLED=true
DEV_SERVICES_SCRAPER_PORT=8081

# CORS Allowed Origins — REQUIRED in production
# Comma-separated list of allowed origins. In prod, set to the bank's actual domains.
# Example: CORS_ALLOWED_ORIGINS=https://mobilebanking.bank.ae,https://ib.bank.ae
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Graceful Shutdown Timeout (optional, default 60s)
# Reduce in Kubernetes where pod termination grace period is shorter.
# SHUTDOWN_TIMEOUT=60s

# =============================================================================
# IMPORTANT SECURITY NOTES:
# 1. NEVER commit actual API keys to git
# 2. Use strong random keys (minimum 32 characters)
# 3. Different keys for dev/staging/production environments
# 4. Rotate keys quarterly
# 5. Use a key generation command:
#    openssl rand -base64 32 | tr -d "=+/" | cut -c1-32
# 6. DB credentials (SPRING_DATASOURCE_USERNAME/PASSWORD) have NO defaults in
#    production — the app will refuse to start if they are not provided.
